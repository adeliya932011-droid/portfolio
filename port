    <script>
        // Advanced Particle System
        function createParticles() {
            const particleCount = 50;
            const particlesContainer = document.getElementById('particles');
            
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.width = particle.style.height = (Math.random() * 4 + 1) + 'px';
                particle.style.animationDuration = (Math.random() * 20 + 15) + 's';
                particle.style.animationDelay = Math.random() * 5 + 's';
                particlesContainer.appendChild(particle);
            }
        }

        // Parallax & Smooth Scrolling
        window.addEventListener('scroll', () => {
            const scrolled = window.pageYOffset;
            // Parallax effect for hero section is removed to avoid conflicts with scroll snap and particle background
            // const parallax = document.querySelector('#hero');
            // parallax.style.transform = `translateY(${scrolled * 0.3}px)`;
            
            // Dynamic nav opacity and style
            const sections = document.querySelectorAll('section');
            let currentSectionIndex = -1; // Initialize to -1 to handle cases before the first section
            
            sections.forEach((section, index) => {
                // Adjust threshold for when the link should be active
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (window.scrollY >= sectionTop - sectionHeight * 0.5) {
                    currentSectionIndex = index;
                }
            });
            
            document.querySelectorAll('nav a').forEach((link, index) => {
                if (index === currentSectionIndex) {
                    link.style.opacity = '1';
                    link.style.transform = 'scale(1.05)';
                    link.style.boxShadow = '0 10px 40px var(--accent-glow)'; // Add glow on active link
                    link.style.borderColor = 'transparent'; // Remove border on active link
                } else {
                    link.style.opacity = '0.6';
                    link.style.transform = 'scale(1)';
                    link.style.boxShadow = 'none'; // Remove glow on inactive links
                    link.style.borderColor = 'var(--glass-glow)'; // Restore border color
                }
            });
        });

        // Staggered Animations using Intersection Observer
        const observerOptions = {
            threshold: 0.2, // Trigger when 20% of the element is visible
            rootMargin: '0px 0px -50px 0px' // Start animation slightly before element enters viewport
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry, index) => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                    // Note: Setting individual delays here might override the CSS transitions.
                    // It's often better to rely on CSS transitions or stagger them via JS if needed.
                    // For simplicity, we'll rely on the default transition timing.
                }
            });
        }, observerOptions);

        // Observe elements for staggered animations
        document.querySelectorAll('.stat-card, .skill-tag, .project-card').forEach((el, index) => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(60px)';
            el.style.transition = 'all 0.8s cubic-bezier(0.23, 1, 0.32, 1)';
            // Optional: Add a slight delay for staggering effect if CSS transitions aren't enough
            el.style.transitionDelay = `${index * 0.08}s`; 
            observer.observe(el);
        });

        // Observe hero section for initial animation
        const heroObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.querySelector('.hero-title').classList.add('animate-title');
                    entry.target.querySelector('.hero-subtitle').classList.add('animate-subtitle');
                    heroObserver.unobserve(entry.target); // Only animate once
                }
            });
        }, { threshold: 0.5 });
        heroObserver.observe(document.querySelector('#hero'));

        // Add animation class to hero title and subtitle for better control
        const heroTitle = document.querySelector('.hero-title');
        const heroSubtitle = document.querySelector('.hero-subtitle');
        if(heroTitle) heroTitle.classList.add('animate-title');
        if(heroSubtitle) heroSubtitle.classList.add('animate-subtitle');

        // Apply animation keyframes dynamically if needed, or rely on CSS
        // For this case, CSS keyframes are already defined.

        // Initialize particles
        createParticles();
    </script>
